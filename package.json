{
  "name": "antigravity-multi-id-quota",
  "displayName": "Antigravity Multi-ID Quota",
  "description": "🚀 Real-time AI quota dashboard for Antigravity — multi-account monitoring, model pinning, sparkline analytics, smart alerts & cross-platform support (Win/Mac/Linux).",
  "version": "1.1.4",
  "publisher": "ManaphatDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ManaphatDev/Antigravity-Multi-ID-Quota.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "quota",
    "gemini",
    "antigravity",
    "usage",
    "tracker"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agq.showDashboard",
        "title": "AGQ: Open Quota Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "agq.refresh",
        "title": "AGQ: Refresh Quota",
        "icon": "$(refresh)"
      },
      {
        "command": "agq.openDashboard",
        "title": "AGQ: Open Quota Dashboard"
      }
    ],
    "configuration": {
      "title": "Antigravity Multi-ID Quota",
      "properties": {
        "agq.quotaLimit": {
          "type": "number",
          "default": 1500,
          "description": "Daily request quota limit"
        },
        "agq.tokenLimit": {
          "type": "number",
          "default": 1000000,
          "description": "Daily token quota limit"
        },
        "agq.refreshInterval": {
          "type": "number",
          "default": 15,
          "description": "Auto-refresh interval in seconds"
        },
        "agq.warningThreshold": {
          "type": "number",
          "default": 70,
          "description": "Usage percentage to show warning (yellow)"
        },
        "agq.criticalThreshold": {
          "type": "number",
          "default": 90,
          "description": "Usage percentage to show critical (red)"
        },
        "agq.showTokens": {
          "type": "boolean",
          "default": true,
          "description": "Show token usage in status bar"
        },
        "agq.statusBarPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "Status bar item position"
        },
        "agq.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable quota alerts when running low or after reset"
        },
        "agq.notificationWarningThreshold": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Percentage below which a warning notification is triggered (default: 20%)"
        },
        "agq.enableOptimisticReset": {
          "type": "boolean",
          "default": true,
          "description": "Optimistically predict quota reset to 100% locally when the exact reset time is reached, instead of waiting for API sync."
        },
        "agq.dashboardTheme": {
          "type": "string",
          "enum": [
            "classic",
            "native",
            "vibrant",
            "custom"
          ],
          "default": "classic",
          "description": "Default theme for the Quota Dashboard"
        },
        "agq.customTheme.background": {
          "type": "string",
          "default": "#0f172a",
          "description": "Background HEX color for the Custom Theme"
        },
        "agq.customTheme.card": {
          "type": "string",
          "default": "#1e293b",
          "description": "Card background HEX color for the Custom Theme"
        },
        "agq.customTheme.accent": {
          "type": "string",
          "default": "#38bdf8",
          "description": "Accent HEX color (progress bars, borders) for the Custom Theme"
        },
        "agq.customTheme.textPrimary": {
          "type": "string",
          "default": "#f8fafc",
          "description": "Primary text HEX color for the Custom Theme"
        },
        "agq.customTheme.textSecondary": {
          "type": "string",
          "default": "#94a3b8",
          "description": "Secondary text HEX color for the Custom Theme"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agq-sidebar",
          "title": "Antigravity Multi-ID Quota",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "agq-sidebar": [
        {
          "type": "webview",
          "id": "agq.sidebarView",
          "name": "Quota Overview",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}